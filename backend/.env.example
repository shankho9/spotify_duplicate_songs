APP_NAME=Spotify Duplicate Cleaner API
ENVIRONMENT=development
FRONTEND_ORIGIN=http://localhost:3000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/spotify_cleaner
SPOTIFY_API_BASE_URL=https://api.spotify.com/v1
# Ease Spotify 429s: pause after each OK response + slower playlist pagination (see app/core/config.py defaults)
SPOTIFY_REQUEST_DELAY_SECONDS=0.2
SPOTIFY_PLAYLISTS_INTER_PAGE_DELAY_SECONDS=0.75
# If Spotify says wait longer than this (seconds), return 429 to the browser instead of sleeping inside the API (default 15). Set 0 to always retry in-process.
SPOTIFY_MAX_INLINE_429_WAIT_SECONDS=15
API_RATE_LIMIT_PER_MINUTE=120
AUTH_SHARED_SECRET=replace-me
